rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Kullanıcı giriş yapmış mı?
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Kullanıcı kendi verisine mi erişiyor?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Kullanıcı admin mi?
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      // Kullanıcılar kendi profillerini okuyabilir
      // Adminler tüm kullanıcıları okuyabilir
      allow read: if isOwner(userId) || isAdmin();
      
      // Kayıt sırasında kullanıcı kendi dokümanını oluşturabilir
      // Rol sadece 'user' veya 'admin' olabilir (admin için özel e-posta kontrolü)
      allow create: if isOwner(userId) && 
                       request.resource.data.keys().hasAll(['name', 'email', 'role']) &&
                       (request.resource.data.role == 'user' || 
                        (request.resource.data.role == 'admin' && 
                         request.resource.data.email == 'direncuy@gmail.com'));
      
      // Kullanıcılar kendi profillerini güncelleyebilir (rol değiştirilemez)
      allow update: if isOwner(userId) && 
                       request.resource.data.role == resource.data.role;
      
      // Adminler herhangi bir kullanıcıyı güncelleyebilir ve silebilir
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // SHOPS & PRODUCTS TRANSACTIONS
    // ============================================
    match /shops/{shopId} {
      // Herkes okuyabilir
      allow read: if true;
      // Dükkan yazma işlemleri kesinlikle SADECE adminler içindir
      allow create, update, delete: if isAdmin();
    }
    
    match /products/{productId} {
      // Herkes ürünleri görebilir
      allow read: if true;
      
      // Ürün yaratma, düzenleme, silme kesinlikle SADECE adminler içindir
      allow create: if isAdmin() &&
                       request.resource.data.keys().hasAll(['name', 'shopId', 'price', 'isActive']) &&
                       request.resource.data.price > 0;
      
      allow delete: if isAdmin();
      
      // Güncelleme: Adminler her şeyi güncelleyebilir.
      // Kullanıcılar SADECE müzayede alanlarına (teklif, stok, bitiş süresi) dokunabilir.
      allow update: if isAdmin() || (
                       isAuthenticated() && 
                       resource.data.saleType == 'auction' &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['currentHighestBid', 'currentHighestBidderId', 'updatedAt', 'stock', 'auctionEndTime'])
                    );

        // Teklifler alt koleksiyonu - herkese açık okuma, sadece kendi adına teklif verme
        match /bids/{bidId} {
          allow read: if true;
          allow create: if isAuthenticated() && 
                           request.resource.data.userId == request.auth.uid;
        }
    }
    
    // ============================================
    // ORDERS COLLECTION
    // ============================================
    match /orders/{orderId} {
      // Kullanıcılar sadece kendi siparişlerini okuyabilir, adminler her şeyi okuyabilir
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || 
                     isAdmin();
      
      // Giriş yapmış kullanıcılar güvenlik kontrollerini geçerek sipariş oluşturabilir
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'items', 'totalPrice', 'status']) &&
                       request.resource.data.totalPrice > 0;
      
      // Sipariş yönetimi (status güncellemesi) sadece admine aittir
      allow update: if isAdmin();
      // Silme yasaktır
      allow delete: if false;
    }
    
    // ============================================
    // BLOGPOSTS COLLECTION
    // ============================================
    match /blogposts/{postId} {
      // Herkes yayınlanmışları görebilir, adminler hepsini görebilir
      allow read: if resource.data.status == 'published' || isAdmin();
      // İçerik yönetimi sadece adminler içindir
      allow create, update, delete: if isAdmin();
    }
    
    // ============================================
    // DEFAULT DENY
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
